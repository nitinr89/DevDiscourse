                        <li class="item"> <a href="/news-analysis" class="linkBtn" title="News" id="newsLink">NEWS</a> </li>
                        <li class="item"> <a href="/research" class="linkBtn" title="Research" id="researchLink">RESEARCH</a> </li>
                        <li class="item"> <a href="/live-discourse" class="linkBtn" title="Livediscourse" id="livediscourseLink">LIVE DISCOURSE</a> </li>
                        <li class="item"> <a href="/blogs" class="linkBtn" title="Analysis / Blog / Opinion" id="blogLink">BLOG / OPINION</a> </li>
                        <li class="item"> <a href="/blogs/interview" class="linkBtn" title="Interview" id="interviewLink">INTERVIEW</a> </li>

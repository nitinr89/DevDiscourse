    }

    @if (!isCrawler)
    {
    <script>
    $(document).ready(function () {
        loadArticleAi(false);

        function loadArticleAi(forceRefresh) {
            var $card = $('#articleAiCard');
            var $body = $('#articleAiBody');
            var $footer = $('#articleAiFooter');
            $card.show();
            $body.html('<div class="article-ai-loading"><span class="article-ai-dot"></span><span class="article-ai-dot"></span><span class="article-ai-dot"></span><span style="margin-left:8px;color:#888;font-size:13px;">Analyzing article...</span></div>');
            $footer.hide();

            var apiUrl = '/api/Search/GetArticleAiSummary/' + newsId;
            if (forceRefresh) apiUrl += '?refresh=true';

            $.ajax({
                url: apiUrl,
                type: 'GET',
                dataType: 'json',
                timeout: 20000,
                success: function (resp) {
                    if (resp.success) {
                        try {
                            var items = typeof resp.summary === 'string' ? JSON.parse(resp.summary) : resp.summary;
                            if (Array.isArray(items) && items.length > 0) {
                                var html = '<ul>';
                                for (var k = 0; k < items.length; k++) {
                                    html += '<li>' + $('<span/>').text(items[k]).html() + '</li>';
                                }
                                html += '</ul>';
                                $body.html(html);
                                $footer.show();
                                var now = new Date();
                                var ts = now.getHours() + ':' + (now.getMinutes() < 10 ? '0' : '') + now.getMinutes();
                                var src = resp.cached ? 'Cached' : 'Generated';
                                $footer.find('.article-ai-ts').html('<i class="fa fa-clock-o"></i> ' + src + ' at ' + ts);
                            } else {
                                $card.hide();
                            }
                        } catch (e) {
                            $body.html('<p style="color:#6b7280;font-size:14px;">' + $('<span/>').text(resp.summary).html() + '</p>');
                            $footer.show();
                        }
                    } else {
                        $card.hide();
                    }
                },
                error: function () {
                    $card.hide();
                }
            });
        }

        $(document).on('click', '#articleAiRefresh', function () {
            var $btn = $(this);
            $btn.find('i').addClass('fa-spin');
            loadArticleAi(true);
            setTimeout(function () { $btn.find('i').removeClass('fa-spin'); }, 2000);
        });
    });
    </script>
    }
}

    <script src="~/Scripts/jquery.lazy.min.js" asp-append-version="true"></script>
    <script>
    (function(){
        var fallbackSrc='/AdminFiles/Logo/ic_notFound.svg';
        document.addEventListener('error',function(e){
            var t=e.target;
            if(t.tagName==='IMG' && !t.dataset.fallback){
                t.dataset.fallback='1';
                t.src=fallbackSrc;
                t.alt='Image not available';
            }
        },true);
        // For CSS background-image fallback on lazy-loaded elements
        if(window.jQuery){
            $(document).ready(function(){
                $('.lazy').on('error',function(){
                    $(this).css('background-image','url('+fallbackSrc+')');
                });
            });
        }
    })();
    </script>

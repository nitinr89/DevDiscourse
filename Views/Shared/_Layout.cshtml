    <link rel="stylesheet" type="text/css" href="~/Content/SiteNew.css" asp-append-version="true" />
    <link rel="stylesheet" type="text/css" href="~/Content/SiteModern.css" asp-append-version="true" />
    <style>
        body {
            font-family: 'Frank Ruhl Libre',serif;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            text-rendering: optimizeLegibility;
            animation: 0s ease 0s 1 normal none running none;
            transition: all 0.5s ease;
            -webkit-transition: all 0.5s ease;
            line-height: 1.6;
            background-color: #fff;
        }

        #navBtn h1 {
            display: none;
        }

        .font-oswald {
            font-family: 'Oswald',sans-serif;
            font-weight: 400;
        }

        .hovermenu:hover {
            color: red
        }

        .renderBody {
            outline: transparent
        }

        nav.navscrollmenu {
            background-color: #4d4d4d;
            overflow-x: auto;
            overflow-y: hidden;
            white-space: nowrap;
            z-index: 500
        }

            nav.navscrollmenu .item {
                display: inline-block
            }

            nav.navscrollmenu .dropdown {
                float: right
            }

        .item-right {
            float: right
        }

        .b-l-0 {
            border-left-width: 0
        }

        .b-r-0 {
            border-right-width: 0
        }

        .sortupIcon {
            position: absolute;
            color: #ededed !important;
            margin-left: 180px;
            margin-top: -19px
        }

        .globeBtn {
            padding: 20px 14px 14px 14px;
            cursor: pointer
        }

            .globeBtn.active {
                border-top: 3px solid #ff7b00;
                padding-top: 18px
            }

            .globeBtn:hover {
                background-color: #777
            }

        .header-list > li > a.linkBtn.active, .header-list > li > a.linkBtn:hover {
            color: #ff7b00;
        }

        .login-dropdown {
            position: absolute;
            right: 15px;
            background-color: #fff;
            min-width: 200px;
            z-index: 1000;
            display: none;
            -webkit-box-shadow: 0 6px 12px rgba(0,0,0,.175);
            box-shadow: 0 6px 12px rgba(0,0,0,.175);
            transition: .5s ease;
            font-family: 'Oswald',sans-serif
        }

            .login-dropdown.open {
                display: block
            }

            .login-dropdown li a {
                display: block;
                padding: 8px 20px;
                border-bottom: 1px solid #f1f1f1;
                clear: both;
                font-weight: 400;
                line-height: 1.42857143;
                color: #333;
                text-decoration: none;
                white-space: nowrap
            }

                .login-dropdown li a .fa {
                    margin-right: 5px
                }

                .login-dropdown li a:hover {
                    text-decoration: none;
                    background-color: #efefef;
                }

        .header-list > li {
            border-right: 1px solid #e0e0e0;
            padding-left: 12px;
            padding-right: 12px;
        }

            .header-list > li:last-child {
                border-right: 0;
            }

            .header-list > li > a {
                color: #707070;
                font-size: 13px;
                letter-spacing: 0.3px;
                transition: color 0.2s ease;
            }

            .header-list > li > a:hover {
                color: #ff7b00;
            }

        .header-cont {
            background-color: rgba(255,255,255,0.98);
            padding-bottom: 0;
            border-bottom: 1px solid #eee;
            box-shadow: 0 1px 6px rgba(0,0,0,0.06);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            z-index: 1000;
        }

        /* Utility Bar */
        .utility-bar {
            background-color: #f8f8f8;
            border-bottom: 1px solid #eee;
            padding: 0;
            line-height: 28px;
        }

        .utility-bar .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .utility-bar .header-list > li {
            border-right: 1px solid #e0e0e0;
            padding: 0 10px;
        }

        .utility-bar .header-list > li:first-child {
            padding-left: 0;
        }

        .utility-bar .header-list > li:last-child {
            border-right: 0;
        }

        .utility-bar .header-list > li > a {
            color: #666;
            font-size: 12px;
            letter-spacing: 0.3px;
        }

        .utility-bar .header-list > li > a:hover {
            color: #ff7b00;
        }

        /* Main Header Row */
        .main-header-row {
            padding: 6px 0;
        }

        .search-icon-btn {
            display: inline-block;
            width: 34px;
            height: 34px;
            line-height: 34px;
            text-align: center;
            border-radius: 50%;
            color: #555;
            font-size: 15px;
            transition: all 0.2s ease;
            border: 1px solid #ddd;
        }

        .search-icon-btn:hover {
            background-color: #ff7b00;
            color: #fff;
            border-color: #ff7b00;
            text-decoration: none;
        }

        /* Sector Nav Bar */
        .sector-nav-bar {
            background-color: #4d4d4d;
            margin-top: 0;
            padding: 0;
        }

        ul.scrollmenu {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .p-t-10 {
            padding-top: 10px;
        }

        .main-nav {
            font-size: 13px;
            margin-bottom: 0;
            margin-top: 0;
            font-family: "oswald";
            letter-spacing: 0.8px;
        }

        .main-nav .item {
            margin: 0 1px;
        }

        .main-nav .item a.linkBtn {
            padding: 6px 8px;
            color: #333;
            display: inline-block;
            position: relative;
            transition: color 0.2s ease;
        }

        .main-nav .item a.linkBtn:hover,
        .main-nav .item a.linkBtn.active {
            color: #ff7b00;
        }

        .main-nav .item a.linkBtn.active::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 20px;
            height: 2px;
            background-color: #ff7b00;
            border-radius: 1px;
        }

        .fg-color {
            color: #ff6a00;
        }

        .font-sans-serif {
            font-family: sans-serif;
        }

        .p-t-15 {
            padding-top: 15px;
        }

        .navBtn {
            padding-right: 10px;
        }

        .trend-number {
            color: #f0f2f5;
            position: absolute;
            right: 0;
            z-index: -1;
            font-size: 48px;
            line-height: 28px;
            font-weight: 700;
        }

        .trend-title {
            font-size: 17px;
            font-weight: 500;
            line-height: 1.35;
            color: #333;
            padding-right: 5px;
            transition: color 0.2s ease;
        }

        .ls-1 {
            letter-spacing: 1px;
        }

        .badge-tag {
            padding: 3px 10px;
            color: #fff;
            background-color: #ff7b00;
            float: right;
            border-radius: 3px;
            font-size: 11px;
            letter-spacing: 0.5px;
        }

        @@media screen and (max-width:1500px) {
            nav.navscrollmenu .dropdown, .item-right {
                float: none
            }
        }

        @@media(max-width:1024px) {
            .cp-0 {
                padding-left: 0;
                padding-right: 0;
            }
        }

        @@media screen and (max-width:768px) {
            nav.navscrollmenu {
                padding-left: 35px
            }

            .header-cont {
                padding-top: 0;
                padding-bottom: 0;
            }

            .main-header-row {
                padding: 4px 0;
            }

            .cp-0 {
                padding-left: 15px;
                padding-right: 15px;
            }

            #NewsSector {
                transition: left 0.3s ease;
                z-index: 99999 !important;
            }

            #NewsSector .sector-nav-bar {
                background-color: #fff !important;
                padding: 10px 0 !important;
            }

            #NewsSector ul.scrollmenu {
                text-align: left !important;
            }

            #NewsSector ul.scrollmenu a {
                color: #333 !important;
                display: block !important;
                text-align: left !important;
                font-size: 15px !important;
                padding: 10px 15px !important;
                border-bottom: 1px solid #eee;
                text-decoration: none;
            }

            #NewsSector ul.scrollmenu a:hover {
                color: #ff7b00 !important;
                background-color: #f9f9f9;
            }

            #navBtn {
                position: relative;
                z-index: 99999;
                cursor: pointer;
                -webkit-tap-highlight-color: transparent;
            }
        }

        @@media screen and (max-width:425px) {
            .login-dropdown {
                position: absolute;
                right: 0;
                width: 100%;
                background-color: #fff
            }

            .infocus-bg-heading {
                font-size: 22px;
                padding: 10px 15px;
            }

            .trend-title {
                font-size: 18px
            }

            body {
                padding-top: 60px;
            }

            .main-header-row {
                padding: 3px 0;
            }

            .full-width {
                width: 100%;
            }

            .width-100 {
                width: 100px;
            }

            .header-cont .row div {
                padding-left: 5px;
                padding-right: 5px;
            }

            #regionInputGroup {
                margin-top: 10px;
            }
        }

        #news-alert {
            overflow: auto;
        }

            #news-alert::-webkit-scrollbar {
                width: 5px
            }

            #news-alert::-webkit-scrollbar-track {
                background: #f1f1f1
            }

            #news-alert::-webkit-scrollbar-thumb {
                background: #ff7a00
            }

                #news-alert::-webkit-scrollbar-thumb:hover {
                    background: #555
                }</style>

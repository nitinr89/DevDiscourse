        .article-ai-header { padding: 12px 12px 0; }
        .article-ai-title { font-size: 30px; }
        .article-ai-body { padding: 10px 12px 8px; font-size: 15px; }
        .article-ai-body ul li { font-size: 14px; line-height: 1.4; }
        .article-ai-footer { padding: 8px 10px 10px; }

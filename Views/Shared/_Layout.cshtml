    <link rel="icon" type="image/png" sizes="32x32" href="https://www.devdiscourse.com/AdminFiles/Favicon/favicon-32x32.png" />
    <link rel="manifest" href="https://www.devdiscourse.com/AdminFiles/Favicon/manifest.json" />

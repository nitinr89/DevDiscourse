        default:
            ViewBag.Title = "Development News, Breaking News, Science News, Political News, Business News | Devdiscourse";
            ViewBag.pageKeywords = "International Development News, Breaking News, Tech News, Science News";
            ViewBag.PageDescription = "Devdiscourse provides Breaking News, Daily News, International Development News, Sustainable Development, Energy, Economy, Finance, Transport, Education, Digital Development,Industry, Agro-Forestry, Social Protection,Public Administration, Water and Sanitation, Health News";

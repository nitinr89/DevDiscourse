@using System.Globalization;
@{
    string sectorSlug = ViewBag.sectorSlug.ToString();
    string domainUrl = "https://www.devdiscourse.com";
    string imageUrl = "/AdminFiles/Logo/devediscourse_banner.png?w=920";
    string region = ViewBag.region;
    ViewBag.webEdition = region;
    var newsImage = imageUrl.IndexOf("devdiscourse.blob.core.windows.net") != -1 ? imageUrl : string.Concat(domainUrl, imageUrl);
    ViewBag.PageImage = newsImage;
    string coverImage = "";
    string accentColor = "#2196F3";
    string gradientFrom = "#1a237e";
    string gradientTo = "#0d47a1";
    string sectorIcon = "fa-newspaper-o";
    TempData["Sector"] = ViewBag.sector;
}

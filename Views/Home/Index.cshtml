                </div>
            }
            else
            {
                <div class="clearfix m-t-30 m-b-30">
                    <div class="advertisement-area padding-l-r-5">
                        <div class="advertisement-title">Advertisement</div>
                        <a href="https://visionri.com/insight/22-refugee-compassion-and-response-ideas-to-mitigate-disasters-now-and-in-their-future" target="_blank" rel="noopener"><img src="~/AdminFiles/COE/refugee_728x90.jpg" class="img-responsive center-block m-t-10 m-b-10" alt="add-banner"></a>
                    </div>
                </div>
            }
        </div>
        <div class="col-md-5 p-t-10">
            <h2 class="section-title" title="EDUCATION NEWS">
                <span>EDUCATION</span>
            </h2>
            <cache expires-after="@TimeSpan.FromMinutes(1)" vary-by-query="@edition">
                @await Component.InvokeAsync("EducationNews", new { reg = edition })

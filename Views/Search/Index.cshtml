            ViewBag.PageDescription = "Devdiscourse provides News about water and sanitation, hygiene, sanitation and health, sanitation trends, policy, programs, investments, sanitation awareness, solid waste management, water supply, sewerage system, rural sanitation and ODF.";
            ViewBag.PostUrl = "https://www.devdiscourse.com/news/wash";

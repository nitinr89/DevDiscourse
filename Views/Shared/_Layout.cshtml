    <script>
    // Complete mobile sidebar toggle — self-contained, no dependency on layout.min.js
    (function(){
        if (typeof jQuery === 'undefined') return;
        $(function(){
            var $nav = $('#NewsSector');
            var $btn = $('#navBtn');
            var $backdrop = $('#sidebarBackdrop');
            var isOpen = false;

            function openMenu() {
                isOpen = true;
                $nav[0].style.setProperty('left', '0px', 'important');
                $nav[0].style.setProperty('z-index', '9999', 'important');
                $backdrop.css({ display: 'block' });
                requestAnimationFrame(function(){
                    $backdrop.css({ opacity: 1 });
                });
            }

            function closeMenu() {
                isOpen = false;
                $nav[0].style.setProperty('left', '-250px', 'important');
                $backdrop.css({ opacity: 0 });
                setTimeout(function(){ $backdrop.css({ display: 'none' }); }, 300);
            }

            $btn.on('click', function(e){
                e.preventDefault();
                e.stopPropagation();
                if (isOpen) closeMenu(); else openMenu();
            });

            $backdrop.on('click', function(){
                closeMenu();
            });

            $nav.on('click', 'a', function(){
                closeMenu();
            });
        });
    })();
    </script>

    <link rel="publisher" href="https://www.facebook.com/devdiscourse" />
    <meta name="news_keywords" content="@ViewBag.pageKeywords" />
    <meta itemprop="name" content="@ViewBag.Title" />
    <meta itemprop="description" content="@ViewBag.PageDescription" />
    <meta itemprop="image" content="@pageImage&format=jpeg" />
    <meta itemprop="thumbnailUrl" href="@pageImage&format=jpeg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@dev_twitter" />
    <meta name="twitter:creator" content="@dev_twitter" />
    <meta property="fb:app_id" content="253802031818293" />
    <meta property="fb:pages" content="317536492049394" />
    <meta property="og:url" content="@ViewBag.PostUrl" />

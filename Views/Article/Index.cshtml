        font-size: 11px;
        padding: 4px 12px;
        border-radius: 20px;
        cursor: pointer;
        font-weight: 600;
        font-family: sans-serif;
        transition: all 0.2s ease;
    }

    .article-ai-refresh:hover {
        background: #ff8a1a;
        color: #fff;
        border-color: #ff8a1a;
    }

    .article-ai-loading {
        display: flex;
        align-items: center;
        padding: 4px 0;
    }

    .article-ai-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #ff7b00;
        display: inline-block;
        margin: 0 3px;
        animation: articleAiBounce 1.4s infinite ease-in-out both;
    }

    .article-ai-dot:nth-child(1) { animation-delay: -0.32s; }
    .article-ai-dot:nth-child(2) { animation-delay: -0.16s; }

    @@keyframes articleAiBounce {
        0%, 80%, 100% { transform: scale(0); opacity: 0.4; }
        40% { transform: scale(1); opacity: 1; }
    }

    @@media (max-width: 768px) {
        .article-ai-card {
            margin: 10px 0 12px;
            border-radius: 10px;
